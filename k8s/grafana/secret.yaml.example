# Template for the Grafana admin credentials Secret.
#
# This file is committed as documentation only — it is NOT applied as-is.
# Copy it to secret.yaml (gitignored) and set a real password, or create the
# Secret imperatively instead of storing it in a file at all:
#
#   kubectl create secret generic grafana-admin \
#     --namespace monitoring \
#     --from-literal=admin-password='<your-password>'
#
# In a production setup this would be managed by a secrets manager
# (e.g. Vault, External Secrets Operator, Sealed Secrets) rather than
# either of the above.
apiVersion: v1
kind: Secret
metadata:
  name: grafana-admin
  namespace: monitoring
type: Opaque
stringData:
  admin-password: "changeme"
